APP_NAME=Adbot API
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/adbot
RETRIEVAL_TOP_K=10
VECTOR_RETRIEVAL_ENABLED=true
EMBEDDING_MODEL_NAME=hashing:384
EMBEDDING_DIMENSIONS=384
RERANKER_ENABLED=true
RERANKER_MODEL_NAME=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=3
RERANKER_BATCH_SIZE=8
RERANKER_DEVICE=cpu
